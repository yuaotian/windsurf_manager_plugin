# 忽略本地依赖与构建产物，避免把机器相关文件提交到仓库。
node_modules/
dist/
out/
coverage/
artifacts/
*.tsbuildinfo

# 忽略本地打包、调试和网络抓包产物。
*.vsix
*.log
*.har
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 忽略本地配置、密钥与三术记忆数据。
.env
.env.*
.vscode/
.sanshu-memory/

# 忽略总结文档目录，保留本地文件但不再纳入 Git 跟踪。
docs/

# 忽略操作系统生成的临时文件。
.DS_Store
Thumbs.db
